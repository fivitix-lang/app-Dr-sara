rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: patients
    // Document ID: auto-generated or patientId
    // Fields:
    //   - ficheNo: string (required)
    //   - cin: string (required)
    //   - nom: string (required)
    //   - prenom: string (required)
    //   - sexe: string (required, Masculin/Féminin)
    //   - dateCreation: timestamp
    //   - dateNaissance: string
    //   - profession: string
    //   - adresse: string
    //   - telephone: string
    //   - matriculeAssurance: string
    //   - typeAssurance: string
    //   - validiteAssurance: string
    //   - codeAPCI: string
    //   - createdBy: string (immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jamalnettttt@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['ficheNo', 'nom', 'prenom', 'sexe', 'cin']) &&
             data.ficheNo is string && data.ficheNo.size() > 0 &&
             data.nom is string && data.nom.size() > 0 &&
             data.prenom is string && data.prenom.size() > 0 &&
             data.sexe in ['Masculin', 'Féminin'] &&
             data.cin is string && data.cin.size() > 0 &&
             (!('telephone' in data) || data.telephone is string) &&
             (!('adresse' in data) || data.adresse is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPatient(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidPatient(request.resource.data) && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAdmin();
    }

    match /medical_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
